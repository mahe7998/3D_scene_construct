# Environment Configuration for 3D Scene Construction System

# =============================================================================
# RENDERING SETTINGS
# =============================================================================
RENDER_RESOLUTION=512
RENDER_SAMPLES=128
RENDER_ENGINE=CYCLES
RENDER_DEVICE=GPU
RENDER_VIEWS_PER_OBJECT=12
RENDER_FORMAT=JPEG
RENDER_QUALITY=90

# =============================================================================
# ASSET MANAGEMENT
# =============================================================================
ASSET_COUNT=1000
ASSET_SOURCE=objaverse
ASSET_BATCH_SIZE=10
ASSET_DOWNLOAD_WORKERS=4

# =============================================================================
# VISION LLM SETTINGS
# =============================================================================
VISION_MODEL=llava-1.6-vicuna-7b
VISION_MODEL_PATH=/data/models/llava
VISION_BATCH_SIZE=8
VISION_MAX_LENGTH=512
VISION_TEMPERATURE=0.7

# =============================================================================
# SCENE GENERATION
# =============================================================================
SCENE_COMPLEXITY_START=1
SCENE_COMPLEXITY_MAX=5
SCENE_OBJECTS_MIN=1
SCENE_OBJECTS_MAX=10
SCENE_GROUND_TYPES=flat,terrain,urban

# =============================================================================
# REINFORCEMENT LEARNING
# =============================================================================
RL_ALGORITHM=PPO
RL_LEARNING_RATE=0.0003
RL_TOTAL_TIMESTEPS=1000000
RL_N_ENVS=4
RL_N_STEPS=2048
RL_BATCH_SIZE=64
RL_GAMMA=0.99
RL_GAE_LAMBDA=0.95

# Reward weights
RL_REWARD_OBJECT_ID=0.3
RL_REWARD_POSITION=0.25
RL_REWARD_ROTATION=0.15
RL_REWARD_SCALE=0.1
RL_REWARD_COMPLETENESS=0.15
RL_REWARD_FALSE_POSITIVE=-0.05

# =============================================================================
# HARDWARE SETTINGS
# =============================================================================
GPU_DEVICE=0
NUM_WORKERS=4
CUDA_VISIBLE_DEVICES=0
PYTORCH_CUDA_ALLOC_CONF=max_split_size_mb:512

# =============================================================================
# PATHS
# =============================================================================
DATA_DIR=/data
ASSETS_RAW_DIR=/data/assets/raw
ASSETS_RENDERED_DIR=/data/assets/rendered
DATABASE_DIR=/data/database
MODELS_DIR=/data/models
LOGS_DIR=/data/logs
CHECKPOINTS_DIR=/data/checkpoints

# =============================================================================
# DATABASE
# =============================================================================
DATABASE_TYPE=sqlite
DATABASE_PATH=/data/database/assets.db

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO
TENSORBOARD_PORT=6006
MLFLOW_TRACKING_URI=file:///data/logs/mlflow

# =============================================================================
# TRAINING
# =============================================================================
CHECKPOINT_FREQUENCY=10000
EVALUATION_FREQUENCY=5000
SAVE_BEST_MODEL=true

# =============================================================================
# DOCKER
# =============================================================================
DOCKER_GPU_COUNT=1
DOCKER_SHM_SIZE=8g

# =============================================================================
# OPTIONAL: API KEYS
# =============================================================================
# OPENAI_API_KEY=sk-...  # If using GPT-4V instead of local LLaVA
# HUGGINGFACE_TOKEN=hf_...  # For downloading models from HuggingFace
